APP_NAME=Baixar Videos Privados API
API_PREFIX=/api/v1
ENVIRONMENT=development
PUBLIC_DOWNLOAD_FAILURE_MESSAGE=Nao foi possivel baixar o video.
AUTHORIZATION_CACHE_TTL_SECONDS=180
AUTHORIZATION_CACHE_MAX_SIZE=2000
PROVIDER_RETRY_MAX_ATTEMPTS=3
PROVIDER_RETRY_BASE_DELAY_SECONDS=0.1
DOWNLOAD_WORKER_CONCURRENCY=2
QUEUE_BACKEND=in_process
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_KEY=download_jobs_queue
DOWNLOAD_OUTPUT_DIR=downloads
DOWNLOAD_HTTP_TIMEOUT_SECONDS=120
ALLOWED_SOURCE_HOSTS=
ENABLE_PLATFORM_EXTRACTOR=true
