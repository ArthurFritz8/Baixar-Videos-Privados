APP_NAME=Baixar Videos Privados API
API_PREFIX=/api/v1
ENVIRONMENT=development
PUBLIC_DOWNLOAD_FAILURE_MESSAGE=Nao foi possivel baixar o video.
API_KEY=
API_KEY_HEADER_NAME=X-API-Key
JOB_REPOSITORY_BACKEND=sqlite
SQLITE_DB_PATH=data/download_jobs.db
AUTHORIZATION_CACHE_TTL_SECONDS=180
AUTHORIZATION_CACHE_MAX_SIZE=2000
REQUESTER_RATE_LIMIT_ENABLED=true
REQUESTER_RATE_LIMIT_WINDOW_SECONDS=60
REQUESTER_RATE_LIMIT_MAX_REQUESTS=12
PROVIDER_RETRY_MAX_ATTEMPTS=3
PROVIDER_RETRY_BASE_DELAY_SECONDS=0.1
DOWNLOAD_WORKER_CONCURRENCY=2
QUEUE_BACKEND=in_process
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_KEY=download_jobs_queue
DOWNLOAD_OUTPUT_DIR=downloads
DOWNLOAD_HTTP_TIMEOUT_SECONDS=120
ALLOWED_SOURCE_HOSTS=
ENABLE_PLATFORM_EXTRACTOR=true
EXTRACTOR_CONCURRENT_FRAGMENT_DOWNLOADS=8
DOWNLOAD_QUALITY_DEFAULT=best
DOWNLOAD_FILE_TOKEN_SECRET=change-me-in-prod
DOWNLOAD_FILE_TOKEN_TTL_SECONDS=120
RETENTION_CLEANUP_ENABLED=true
RETENTION_CLEANUP_INTERVAL_SECONDS=3600
TERMINAL_JOB_RETENTION_HOURS=24
METRICS_ENABLED=true
